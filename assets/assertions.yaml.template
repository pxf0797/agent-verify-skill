# ============================================================
# agent-verify Assertions
# 项目: {TARGET_NAME}
# 创建时间: {CURRENT_DATE}
# 版本: {SKILL_VERSION}
# ============================================================
# 本文件定义 Agent 验证的断言规则。
# enabled: false 的断言被引擎跳过，仅作参考。
# MVP 断言类型: tool_call | tool_param | output_match
# V1.0 断言类型: path_sequence | timing | output_schema
# 扩展类型: custom_script
# ============================================================

# --- MVP 断言类型 ---

assertions:
- id: at-least-one-search
  name: Search tool called
  type: tool_call
  target:
    tool_name: web_search
  condition:
    min_count: 1
  severity: error
  enabled: true
- id: search-query-not-empty
  name: Search query not empty
  type: tool_param
  target:
    tool_name: web_search
    param: query
  condition:
    not_null: true
    not_whitespace_only: true
    min_length: 3
  severity: error
  enabled: true
- id: output-contains-answer
  name: Output contains answer
  type: output_match
  target:
    agent: my-agent
  condition:
    pattern: 答案[：:]
    min_matches: 1
    case_sensitive: false
  severity: error
  enabled: true
- id: expensive-tool-capped
  name: Prevent excessive calls
  type: tool_call
  target:
    tool_name: web_scrape
  condition:
    max_count: 3
  severity: warning
  enabled: false


