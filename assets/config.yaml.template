# --- 基线管理配置 ---
baselines:
  enabled: true                  # 是否启用基线管理
  dir: baselines                 # 基线文件存储目录
  auto_save: true                # 回归测试后自动保存基线
  max_kept: 20                   # 最多保留的基线数量
  compare_on_run: true           # 回归测试后自动与最新基线对比

# --- 报告生成配置 ---
reports:
  default_format: markdown       # 默认报告格式: markdown | json | html (V1.0)
  dir: reports                   # 报告输出目录
  include_passed: true           # 报告中是否包含通过的断言详情

