# ============================================================
# agent-verify Configuration
# 项目: {{TARGET_NAME}}
# 创建时间: {{CURRENT_DATE}}
# 版本: {{SKILL_VERSION}}
# ============================================================
# 本配置文件定义了 agent-verify Skill 的全局行为。
# 所有字段均有默认值，建议根据项目需要修改。
# MVP 字段已全部标注，V1.0 字段注释标注。
# ============================================================

# --- 版本 ---
version: "1"          # 配置版本，用于未来兼容性检查

# --- 执行配置 ---
execution:
  mode: sequential               # 执行模式: sequential | parallel (V1.0)
  timeout: 120                   # 每个用例的超时时间（秒）
  stop_on_first_error: false     # 首个断言失败时停止当前用例后续检查
  fail_fast: false               # 首个用例失败时停止整个回归
  fail_fast_threshold: 3         # 连续失败 N 个用例后停止 (fail_fast=false 时生效)
  # max_retries: 1               # (V1.0) 用例失败重试次数
  # retry_delay_ms: 1000         # (V1.0) 重试间隔（毫秒）
  agent_command: "claude --print" # 执行 Agent 的 CLI 命令

# --- 断言引擎配置 ---
assertions:
  default_severity: error        # 默认严重级别: error | warning
  file: assertions.yaml          # 断言定义文件（相对于 agent-verify/）
  fail_on_warning: false         # warning 级别的失败是否视为整体失败
  allow_custom_script: false     # 是否允许执行 custom_script
  custom_script_dir: scripts/custom_checks  # 自定义脚本搜索目录

